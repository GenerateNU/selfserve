# DEPRECATED: This file is for reference only
# Secrets are managed via Doppler
# To set up: doppler login && doppler setup
# To view secrets: doppler secrets
# To manage: https://dashboard.doppler.com/

# Application
APP_PORT=8080
APP_LOG_LEVEL=info
APP_HOST=localhost:8080
APP_CORS_ORIGINS=http://localhost:3000

# Database
DB_HOST=""
DB_PORT=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_SSLMODE=disable

# Clerk
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SIGNATURE=""
CLERK_BASE_URL="" # Optional

# Status
ENV=development

# ngrok
NGROK_DOMAIN=""

# AWS S3
AWS_S3_ACCESS_KEY_ID=""
AWS_S3_SECRET_ACCESS_KEY=""
AWS_S3_REGION=""
AWS_S3_BUCKET_NAME=""

# LLM
LLM_SERVER_ADDRESS=http://127.0.0.1:11434
LLM_MODEL=reaperdoesntrun/Qwen3-0.6B-Distilled:latest
LLM_TIMEOUT=60
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TEMPERATURE=0.2

# OpenSearch
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=
OPENSEARCH_INSECURE_SKIP_TLS=true  # set true for local dev, false for prod
