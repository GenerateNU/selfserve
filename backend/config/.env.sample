# Application
APP_PORT=8080
APP_LOG_LEVEL=info
APP_HOST=localhost:8080
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8080,http://127.0.0.1:8080

# Database
DB_HOST=""
DB_PORT=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_SSLMODE=disable

# Clerk
CLERK_SECRET_KEY=""
